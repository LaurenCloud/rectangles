{
  "manifest_version": 3,
  "name": "Rectangles",
  "version": "0.2.0",
  "description": "Click-and-drag rectangles to cover regions of a page. Live-samples the underlying video so the cover blends in.",
  "action": {
    "default_title": "Rectangles — click to draw"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
